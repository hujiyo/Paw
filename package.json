{
  "name": "paw-desktop",
  "version": "0.1.3",
  "description": "Paw - 智能桌面 AI Agent 应用",
  "main": "dist/main/main.js",
  "author": "Paw Team",
  "license": "Apache-2.0",
  "scripts": {
    "start": "npm run compile && electron .",
    "dev": "npm run compile && electron . --dev",
    "compile": "tsc -p tsconfig.main.json && tsc",
    "watch": "tsc -w",
    "build": "npm run compile && electron-builder",
    "build:win": "npm run compile && electron-builder --win",
    "build:mac": "npm run compile && electron-builder --mac",
    "build:linux": "npm run compile && electron-builder --linux"
  },
  "dependencies": {
    "electron-serve": "^1.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.paw.desktop",
    "productName": "Paw",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "src/backend",
        "to": "backend"
      },
      {
        "from": "paw_env",
        "to": "paw_env",
        "filter": ["**/*"]
      },
      {
        "from": "dist/renderer",
        "to": "renderer"
      },
      {
        "from": "resources/static",
        "to": "static"
      },
      {
        "from": "resources/templates",
        "to": "templates"
      },
      {
        "from": "resources/icons",
        "to": "icons"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icons/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Paw"
    },
    "asar": true
  }
}
